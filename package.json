{
  "name": "doomcraft",
  "private": true,
  "version": "0.1.0",
  "description": "Browser-based 2-player Doom 2 with a Minecraft-style block gun",
  "license": "GPL-2.0-only",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src server tools",
    "typecheck": "tsc --noEmit",
    "gen": "node --experimental-strip-types tools/gen-tables.ts && node --experimental-strip-types tools/gen-info.ts",
    "server": "node --experimental-strip-types server/main.ts"
  },
  "dependencies": {
    "earcut": "^3.0.1",
    "three": "^0.177.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/earcut": "^3.0.0",
    "@types/node": "^24.0.0",
    "@types/three": "^0.177.0",
    "@types/ws": "^8.18.0",
    "eslint": "^9.29.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.34.0",
    "vite": "^7.0.0",
    "vitest": "^3.2.0"
  }
}
